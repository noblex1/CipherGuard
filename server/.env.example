# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Configuration
# Local: mongodb://localhost:27017/cipherguard
# Production (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/cipherguard
MONGODB_URI=mongodb://localhost:27017/cipherguard

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin Default Credentials (Change immediately after first login)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeThisSecurePassword123!

# CORS Configuration
# Development: http://localhost:3000
# Production: https://your-app-name.vercel.app
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Logging
LOG_LEVEL=info
